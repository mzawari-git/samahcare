# =============================================================================
# .HTACCESS - Sawa Rent Car
# Advanced SEO Optimization
# =============================================================================

# -----------------------------------------------------------------------------
# SECURITY - Prevent Directory Listing
# -----------------------------------------------------------------------------
<IfModule mod_autoindex.c>
IndexIgnore *
</IfModule>

# -----------------------------------------------------------------------------
# URL REWRITING - Enable SEO-Friendly URLs
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Remove www (optional - choose one)
# RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Remove trailing slashes (SEO best practice)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Force HTTPS (uncomment after SSL installation)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^sitemap-html\.html$ sitemap-html.php [L]

# Favicon
RewriteRule ^favicon\.ico$ favicon.ico [L]

# Robots
RewriteRule ^robots\.txt$ robots.txt [L]
</IfModule>

# -----------------------------------------------------------------------------
# COMPRESSION - Improve Page Speed
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/plain
AddOutputFilterByType DEFLATE text/css
AddOutputFilterByType DEFLATE text/html
AddOutputFilterByType DEFLATE text/xml
AddOutputFilterByType DEFLATE application/xml
AddOutputFilterByType DEFLATE application/xhtml+xml
AddOutputFilterByType DEFLATE application/javascript
AddOutputFilterByType DEFLATE application/json
AddOutputFilterByType DEFLATE image/svg+xml
AddOutputFilterByType DEFLATE application/x-font-ttf
AddOutputFilterByType DEFLATE application/x-font-otf
</IfModule>

# -----------------------------------------------------------------------------
# BROWSER CACHING - Speed Optimization
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/jpg "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/gif "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"
ExpiresByType image/x-icon "access plus 1 year"
ExpiresByType image/ico "access plus 1 year"
ExpiresByType text/css "access plus 1 month"
ExpiresByType text/javascript "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
ExpiresByType application/json "access plus 1 week"
ExpiresByType application/pdf "access plus 1 week"
ExpiresByType text/xml "access plus 1 week"
ExpiresByType application/xml "access plus 1 week"
ExpiresByType application/x-shockwave-flash "access plus 1 month"
ExpiresByType font/ttf "access plus 1 year"
ExpiresByType font/otf "access plus 1 year"
ExpiresByType font/woff "access plus 1 year"
ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# -----------------------------------------------------------------------------
# SECURITY HEADERS
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
# Prevent clickjacking
Header always set X-Frame-Options "SAMEORIGIN"

# Prevent MIME sniffing
Header always set X-Content-Type-Options "nosniff"

# Referrer Policy
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions Policy
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

# XSS Protection
Header always set X-XSS-Protection "1; mode=block"

# HSTS (uncomment after SSL)
# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

# Cross-Origin
Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
Header always set Cross-Origin-Resource-Policy "cross-origin"
# Header always set Cross-Origin-Embedder-Policy "require-corp" (Removed as it blocks Google Maps iframes)

# Allow Google Maps iframe
Header set Content-Security-Policy "default-src 'self' https: data:; base-uri 'self'; form-action 'self'; frame-ancestors 'self' https://*.google.com https://*.google-maps.com https://maps.google.com https://google.com; frame-src 'self' https://*.google.com https://*.google-maps.com https://maps.google.com https://google.com https://www.youtube-nocookie.com https://www.youtube.com; object-src 'none'; manifest-src 'self'; worker-src 'self'; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; connect-src 'self' https:;"
</IfModule>

# -----------------------------------------------------------------------------
# CACHE CONTROL FOR STATIC FILES
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|ttf|otf|woff|woff2)$">
Header set Cache-Control "public, max-age=2592000, immutable"
</FilesMatch>
</IfModule>

# -----------------------------------------------------------------------------
# PROTECT SENSITIVE FILES
# -----------------------------------------------------------------------------
<FilesMatch "^(database\.sql|.*\.log|.*\.env|.*\.ini|config\.php|db\.php)$">
<IfModule mod_authz_core.c>
Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
Order allow,deny
Deny from all
</IfModule>
</FilesMatch>

# -----------------------------------------------------------------------------
# PROTECT DIRECTORIES
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
RewriteCond %{REQUEST_URI} ^/(logs|config|includes|admin/includes)/
RewriteRule ^ - [F,L]
</IfModule>

# -----------------------------------------------------------------------------
# ERROR PAGES - Custom SEO-Friendly Errors
# -----------------------------------------------------------------------------
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php
ErrorDocument 500 /500.php

# -----------------------------------------------------------------------------
# CHARACTER ENCODING
# -----------------------------------------------------------------------------
AddDefaultCharset UTF-8

# -----------------------------------------------------------------------------
# PHP SETTINGS
# -----------------------------------------------------------------------------
<IfModule mod_php7.c>
php_flag display_errors On
php_flag log_errors On
php_value max_execution_time 300
php_value memory_limit 256M
php_value upload_max_filesize 20M
php_value post_max_size 25M
</IfModule>

# =============================================================================
# END OF .HTACCESS
# =============================================================================
