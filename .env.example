# ============================================
# سماح كير  Environment Configuration
# ============================================
# Copy this file to .env for your environment:
#   Local (XAMPP):  copy .env to .env, edit DB & URL
#   Production:     copy .env to .env, set production values
#
# Pre-built templates available:
#   .env.local       - XAMPP localhost setup
#   .env.production  - Live server setup
#
# Local URL (XAMPP): http://localhost/samahcare/public
# Production URL:    https://your-domain.com
# ============================================

APP_NAME="Samah Care"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=samahcare
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

QUEUE_CONNECTION=sync

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Redis (optional - queue/cache)
# REDIS_CLIENT=predis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=
# REDIS_PORT=6379

# Optional: Meta / Facebook API
# META_APP_ID=
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT=

# Optional: Facebook OAuth
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT=

# Optional: AI Sanitization
# OPENAI_API_KEY=
# CLAUDE_API_KEY=
# LLAMA_BASE_URL=http://localhost:11434

# Optional: LTV ML Service
# LTV_SERVICE_URL=http://localhost:8000

# Security
FORCE_HTTPS=false
SECURITY_HEADERS_ENABLED=false
CSP_ENABLED=false

# Performance
OPCACHE_ENABLED=false
IMAGE_OPTIMIZATION=false
ASSET_OPTIMIZATION=false
