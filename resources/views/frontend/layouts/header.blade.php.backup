}
.mega-menu-all {
    background: linear-gradient(135deg, var(--pink-700), var(--pink-500));
    color: #fff;
    font-weight: 700;
    justify-content: center;
}
.mega-menu-all:hover { color: #fff !important; opacity: 0.9; }
.mobile-toggle { display: none; }
@media (max-width: 768px) {
    .header-search { display: block; order: 3; max-width: 100%; width: 100%; margin-top: 10px; }
    .header-main-content { flex-wrap: wrap; }
    .mobile-toggle { display: flex; }
    .header-nav { display: none; position: fixed; top: 0; right: -280px; width: 280px; height: 100vh; background: #fff; z-index: 1060; box-shadow: var(--shadow-xl); transition: right 0.3s; overflow-y: auto; }
    .header-nav.open { display: block; right: 0; }
    .nav-list { flex-direction: column; padding-top: 60px; }
    .nav-link { padding: 14px 24px; border-bottom: 1px solid var(--gray-200); }
    .mega-menu { position: static; min-width: auto; box-shadow: none; border: none; padding: 0 24px; border-radius: 0; opacity: 1; visibility: visible; transform: none; display: none; }
    .mega-menu-trigger:hover .mega-menu { display: none; }
    .mega-menu-trigger.active .mega-menu { display: block; }
    .mega-menu-grid { grid-template-columns: repeat(2, 1fr); }
    .mobile-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1055; }
    .mobile-overlay.open { display: block; }
    .header-top .header-top-text:not(:first-child) { display: none; }
    
    /* Show mobile slider, hide desktop */
    .desktop-only { display: none !important; }
    .mobile-only { display: block !important; }
    
    /* Mobile Header Top Slider */
    .header-top-slider {
        position: relative;
        height: 32px;
        overflow: hidden;
        text-align: center;
    }
    .header-top-slider .slider-item {
        position: absolute;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        font-size: 0.8rem;
        color: var(--gray-600);
        opacity: 0;
        transform: translateX(100%);
        transition: all 0.5s ease;
    }
    .header-top-slider .slider-item.active {
        opacity: 1;
        transform: translateX(0);
    }
    .header-top-slider .slider-item i {
        color: var(--pink-600);
        font-size: 0.85rem;
    }
}
</style>

<script>
// Mobile Header Top Slider
(function() {
    const slider = document.querySelector('.header-top-slider');
    if (!slider) return;
    
    const items = slider.querySelectorAll('.slider-item');
    let current = 0;
    
    setInterval(() => {
        items[current].classList.remove('active');
        current = (current + 1) % items.length;
        items[current].classList.add('active');
    }, 3000);
})();
</script>

<script>
function toggleMobileMenu() {
    document.getElementById('mainNav').classList.toggle('open');
    document.getElementById('mobileOverlay').classList.toggle('open');
}
document.addEventListener('click', function(e) {
    const nav = document.getElementById('mainNav');
    const toggle = document.getElementById('mobileToggle');
    if (window.innerWidth <= 768 && nav.classList.contains('open') && !nav.contains(e.target) && !toggle.contains(e.target)) {
        nav.classList.remove('open');
        document.getElementById('mobileOverlay').classList.remove('open');
    }
});
</script>
