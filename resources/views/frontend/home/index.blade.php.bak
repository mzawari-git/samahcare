{{-- Recently Viewed --}}
<div id="recentlyViewed" style="display:none;background:var(--gray-50);padding:40px 0;border-top:1px solid var(--gray-100);">
    <div class="container">
        <div class="section-head">
            <h2>شاهدتِ <span style="color:var(--pink-600);">مؤخراً</span></h2>
        </div>
        <div class="row g-3" id="recentlyViewedGrid"></div>
    </div>
</div>

<script>
(function() {
    const viewed = JSON.parse(localStorage.getItem('recentlyViewed') || '[]');
    if (viewed.length < 1) return;
    const section = document.getElementById('recentlyViewed');
    const grid = document.getElementById('recentlyViewedGrid');
    const bp = window.basePath || '';
    section.style.display = 'block';
    grid.innerHTML = viewed.slice(0, 4).map(p => `
        <div class="col-6 col-md-3">
            <a href="${bp}/product/${p.slug}" style="text-decoration:none;">
                <div style="background:#fff;border-radius:12px;overflow:hidden;border:1px solid var(--gray-100);transition:all .3s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,.1)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='none'">
                    ${p.img ? `<img src="${p.img}" style="width:100%;aspect-ratio:1/1;object-fit:cover;">` : '<div style="width:100%;aspect-ratio:1/1;background:var(--gray-100);display:flex;align-items:center;justify-content:center;"><i class="fas fa-box" style="color:var(--gray-300);font-size:2rem;"></i></div>'}
                    <div style="padding:10px;">
                        <div style="font-size:.8rem;font-weight:600;color:var(--gray-800);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${p.name}</div>
                        <div style="font-size:.85rem;font-weight:700;color:var(--pink-600);">${p.price}</div>
                    </div>
                </div>
            </a>
        </div>
    `).join('');
})();
</script>

<script>
function toggleCategories() {
    const btn = document.getElementById('showMoreCats');
    const items = document.querySelectorAll('.category-grid-item');
    const isShowing = btn.dataset.expanded === '1';
    
    items.forEach((el, i) => {
        if (i >= 8) el.style.display = isShowing ? 'none' : '';
    });
    
    btn.dataset.expanded = isShowing ? '0' : '1';
    btn.innerHTML = isShowing 
        ? '<i class="fas fa-chevron-down"></i> عرض المزيد من الأقسام' 
        : '<i class="fas fa-chevron-up"></i> عرض أقل';
}
</script>

@endsection
